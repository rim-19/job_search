# Copy to .env and fill in. The pipeline also accepts these as GitHub Actions secrets.

# Gemini API key from Google AI Studio (https://aistudio.google.com/app/apikey).
# Either name works — GEMINI_API_KEY is preferred; gemini_key is also accepted.
GEMINI_API_KEY=your-gemini-key-here

# Optional: override the model (default gemini-2.0-flash, free tier).
# GEMINI_MODEL=gemini-2.0-flash

# Telegram bot (create via @BotFather, then message the bot once and read chat id
# from https://api.telegram.org/bot<TOKEN>/getUpdates).
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Optional: keep-threshold (default 7) and published site URL used in Telegram msg.
# KEEP_THRESHOLD=7
# SITE_URL=https://rim-19.github.io/job_search/
